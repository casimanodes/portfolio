# Strapi CMS - setze diese Variablen wenn du Strapi verbindest
# Ohne NEXT_PUBLIC_STRAPI_URL werden automatisch Mock-Daten verwendet

# Lokal:
# NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Produktion (deine Railway Strapi URL):
# NEXT_PUBLIC_STRAPI_URL=https://trainer-cms-production.up.railway.app

# Optional: API Token (nur noetig wenn Public Permissions nicht gesetzt)
# STRAPI_API_TOKEN=your-strapi-api-token-here
