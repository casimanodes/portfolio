# Strapi CMS Verbindung
# Ohne NEXT_PUBLIC_STRAPI_URL werden automatisch Mock-Daten verwendet

# Lokal:
# NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Produktion (Strapi Cloud URL):
# NEXT_PUBLIC_STRAPI_URL=https://dein-projekt.strapiapp.com

# Optional: API Token (nur noetig wenn Public Permissions nicht gesetzt)
# STRAPI_API_TOKEN=dein-strapi-api-token
